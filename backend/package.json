{
  "name": "highlightguard-ai-backend",
  "version": "1.0.0",
  "description": "Production-grade backend for HighlightGuard AI sports media protection and intelligence.",
  "main": "src/server.js",
  "scripts": {
    "dev": "nodemon src/server.js",
    "dev:local": "nodemon src/localServer.js",
    "start": "node src/server.js",
    "start:local": "node src/localServer.js",
    "worker": "node src/jobs/workers.js",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev --name init",
    "prisma:deploy": "prisma migrate deploy",
    "seed": "node src/seed/seed.js",
    "seed:local": "node src/seed/localSeed.js",
    "seed:ipl": "node src/seed/iplManualSeed.js",
    "db:reset": "prisma migrate reset --force",
    "check": "node --check src/server.js && node --check src/app.js && node --check src/seed/seed.js"
  },
  "prisma": {
    "seed": "node src/seed/seed.js"
  },
  "keywords": [
    "sports",
    "media-intelligence",
    "copyright",
    "express",
    "prisma",
    "bullmq"
  ],
  "author": "HighlightGuard AI",
  "license": "MIT",
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.21.0",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dayjs": "^1.11.13",
    "dotenv": "^16.4.5",
    "express": "^4.21.1",
    "express-mongo-sanitize": "^2.2.0",
    "express-rate-limit": "^7.4.1",
    "helmet": "^8.0.0",
    "hpp": "^0.2.3",
    "ioredis": "^5.4.1",
    "jsonwebtoken": "^9.0.2",
    "mongodb": "^6.10.0",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "neo4j-driver": "^5.25.0",
    "uuid": "^10.0.0",
    "winston": "^3.17.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "nodemon": "^3.1.7",
    "prisma": "^5.22.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
