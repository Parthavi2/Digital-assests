NODE_ENV=development
PORT=5000
API_BASE_URL=http://localhost:5000
FRONTEND_ORIGIN=http://localhost:3000

DATABASE_URL=postgresql://highlightguard:highlightguard@localhost:5432/highlightguard_ai?schema=public
YOUTUBE_API_KEY=your_youtube_api_key
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB=highlightguard_ai
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=highlightguard

JWT_SECRET=replace_with_a_long_random_secret_for_production
JWT_EXPIRES_IN=7d
BCRYPT_SALT_ROUNDS=12

UPLOAD_DIR=uploads
MAX_UPLOAD_MB=750
ALLOWED_MEDIA_MIME_TYPES=video/mp4,video/quicktime,video/x-msvideo,video/x-matroska,audio/mpeg,audio/wav,image/jpeg,image/png

DASHBOARD_CACHE_TTL_SECONDS=45
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=300
LOG_LEVEL=info
QUEUE_PREFIX=highlightguard
